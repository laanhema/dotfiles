// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "use_system_path_prompts": true,
  "tasks": {
    "enabled": true
  },
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "hard_tabs": false,
  "audio": {
    "experimental.auto_microphone_volume": true
  },
  "close_on_file_delete": true,
  "file_finder": {
    "file_icons": true
  },
  "middle_click_paste": false,
  "minimap": {
    "show": "never"
  },
  "inline_code_actions": false,
  "drag_and_drop_selection": {
    "enabled": false
  },
  "sticky_scroll": {
    "enabled": false
  },
  "excerpt_context_lines": 2,
  "minimum_contrast_for_highlights": 12.0,
  "selection_highlight": true,
  "current_line_highlight": "line",
  "unnecessary_code_fade": 0.3,
  "hide_mouse": "on_typing_and_movement",
  "cursor_shape": "bar",
  "cursor_blink": true,
  "ui_font_weight": 400.0,
  "tab_size": 2,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "toolbar": {
    "code_actions": false,
    "breadcrumbs": false,
    "agent_review": false,
    "selections_menu": false,
    "quick_actions": false
  },
  "relative_line_numbers": "enabled",
  "gutter": {
    "breakpoints": true,
    "folds": true,
    "min_line_number_digits": 3,
    "runnables": false,
    "line_numbers": true
  },
  "horizontal_scroll_margin": 5.0,
  "vertical_scroll_margin": 3.0,
  "expand_excerpt_lines": 5,
  "vim_mode": false,
  "text_rendering_mode": "platform_default",
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 14.0,
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
      "enabled": false
    },
    "git_gutter": "tracked_files",
    "enable_status": true,
    "enable_diff": true
  },
  "edit_predictions": {
    "mode": "subtle",
    "enabled_in_text_threads": true
  },
  "show_edit_predictions": false,
  "disable_ai": false,
  "agent": {
    "sidebar_side": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
      "enable_thinking": true,
      "effort": "high"
    },
    "expand_terminal_card": true,
    "use_modifier_to_send": true,
    "dock": "right",
    "enable_feedback": true,
    "button": true,
    "favorite_models": [],
    "model_parameters": []
  },
  "collaboration_panel": {
    "dock": "left",
    "button": true
  },
  "notification_panel": {
    "button": true
  },
  "git_panel": {
    "tree_view": false,
    "collapse_untracked_diff": false,
    "sort_by_path": false,
    "status_style": "icon",
    "dock": "left",
    "button": true
  },
  "outline_panel": {
    "expand_outlines_with_depth": 100,
    "default_width": 300.0,
    "auto_fold_dirs": true,
    "indent_size": 17.0,
    "folder_icons": true,
    "file_icons": true,
    "dock": "left",
    "button": false
  },
  "zoomed_padding": true,
  "active_pane_modifiers": {
    "border_size": 0.0
  },
  "window_decorations": "client",
  "use_system_window_tabs": false,
  "centered_layout": {
    "right_padding": 0.2,
    "left_padding": 0.2
  },
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enable_preview_file_from_code_navigation": true,
    "enable_preview_from_multibuffer": true,
    "enable_preview_from_file_finder": false,
    "enable_preview_from_project_panel": true,
    "enabled": true
  },
  "tabs": {
    "show_close_button": "hover",
    "close_position": "right",
    "file_icons": true,
    "git_status": true
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false,
    "show": true
  },
  "search": {
    "button": false
  },
  "diagnostics": {
    "inline": {
      "enabled": false,
      "padding": 4
    },
    "button": true
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false
    },
    "alternate_scroll": "on",
    "font_weight": 400.0,
    "shell": "system",
    "blinking": "on",
    "cursor_shape": "bar",
    "font_size": 14.0,
    "font_family": "CommitMono Nerd Font",
    "dock": "bottom",
    "button": true
  },
  "project_panel": {
    "drag_and_drop": false,
    "indent_guides": {
      "show": "always"
    },
    "bold_folder_labels": false,
    "default_width": 240.0,
    "hide_root": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "auto"
    },
    "auto_fold_dirs": false,
    "starts_open": true,
    "auto_reveal_entries": true,
    "indent_size": 17.0,
    "git_status": true,
    "folder_icons": false,
    "file_icons": true,
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
    "dock": "left",
    "button": true
  },
  "title_bar": {
    "show_user_picture": true,
    "show_user_menu": true,
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_branch_name": true,
    "show_menus": true,
    "show_sign_in": true,
    "show_branch_icon": true
  },
  "status_bar": {
    "active_language_button": true,
    "active_encoding_button": "non_utf8",
    "cursor_position_button": false
  },
  "debugger": {
    "button": true
  },
  "prettier": {
    "allowed": true
  },
  "colorize_brackets": true,
  "inlay_hints": {
    "show_background": false
  },
  "completions": {
    "words": "fallback"
  },
  "soft_wrap": "editor_width",
  "indent_guides": {
    "active_line_width": 1,
    "coloring": "indent_aware",
    "line_width": 1,
    "enabled": true
  },
  "scrollbar": {
    "cursors": true,
    "show": "auto",
    "axes": {
      "vertical": true,
      "horizontal": true
    },
    "git_diff": true
  },
  "auto_signature_help": false,
  "scroll_beyond_last_line": "one_page",
  "which_key": {
    "delay_ms": 1000,
    "enabled": true
  },
  "rounded_selection": false,
  "buffer_line_height": "standard",
  "buffer_font_weight": 400.0,
  "show_wrap_guides": true,
  "ui_font_family": "Noto Sans",
  "buffer_font_family": "CommitMono Nerd Font",
  "telemetry": {
    "diagnostics": true,
    "metrics": true
  },
  "session": {
    "trust_all_worktrees": true
  },
  "base_keymap": "VSCode",
  "icon_theme": "Seti Icon Theme",
  "ui_font_size": 14.0,
  "buffer_font_size": 15.0,
  "theme": "VSCode Dark Modern"
}
