{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "background": "#a89984",
          "foreground": "#282828",
          "style": "diamond",
          "template": "{{if .Root}} \uf0e7 <b>{{.UserName}}</b> {{else}} <b>{{.UserName}}</b> {{end}}",
          "trailing_diamond": "\ue0b0",
          "type": "session"
        },
        {
          "background": "#504945",
          "foreground": "#ddc7a1",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_icon": "\uf115",
            "folder_separator_icon": " \ue0b1 ",
            "max_depth": 5,
            "style": "agnoster_short"
          },
          "style": "powerline",
          "template": " \uf115 {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#504945",
          "foreground": "#ddc7a1",
          "leading_diamond": "<transparent,#504945>\ue0b0</>",
          "powerline_symbol": "\ue0b0",
          "style": "diamond",
          "template": " \uf09b {{ .HEAD }} ",
          "type": "git",
          "trailing_diamond": "\ue0b0"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
