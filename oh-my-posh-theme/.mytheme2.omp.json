{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#3A3735",
          "foreground": "#A9B665",
          "style": "diamond",
          "template": "{{if .Root}} \uf0e7 <bold>{{.UserName}}</> {{else}} <bold>{{.UserName}}</> {{end}}",
          "trailing_diamond": "\ue0b0",
          "type": "session"
        },
        {
          "background": "#3A3735",
          "foreground": "#A9B665",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_icon": "\uf115",
            "folder_separator_icon": " \ue0b1 ",
            "max_depth": 2,
            "style": "agnoster_short"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#3A3735",
          "foreground": "#A9B665",
          "leading_diamond": "<transparent,#3A3735>\ue0b0</>",
          "powerline_symbol": "\ue0b0",
          "style": "diamond",
          "template": " {{ .HEAD }} ",
          "type": "git",
          "trailing_diamond": "\ue0b0"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}} \u26a1 {{end}}{{.UserName}} \u2794 📁{{.Folder}}",
  "final_space": true,
  "version": 4
}
